# Copy this file to .env and fill in your own values.

# Feishu / Lark
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_TENANT_ACCESS_TOKEN=

# Target sheets for each data source
FEISHU_KS_URL=
FEISHU_TENCENT_URL=

# Optional: cookie header for the legacy Kuaishou direct-post mode
KUAISHOU_COOKIE=

# Optional: cookie header for Tencent direct-post mode on Linux/Windows
TENCENT_COOKIE=
